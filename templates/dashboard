<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GPS Tracker — Group 2</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    />
    <style>
      :root {
        --bg: #0d1117;
        --surface: #161b22;
        --surface2: #1c2128;
        --border: #30363d;
        --accent: #58a6ff;
        --green: #3fb950;
        --warn: #d29922;
        --danger: #f85149;
        --purple: #bc8cff;
        --text: #e6edf3;
        --muted: #7d8590;
        --dim: #484f58;
        --mono: "JetBrains Mono", monospace;
        --sans: "Inter", system-ui, sans-serif;
      }
      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--sans);
        font-size: 14px;
        height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }

      /* Header */
      .header {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0 18px;
        height: 50px;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
      }
      .logo {
        font-weight: 600;
        font-size: 15px;
        display: flex;
        align-items: center;
        gap: 7px;
      }
      .logo svg {
        color: var(--accent);
      }
      .hdivider {
        width: 1px;
        height: 18px;
        background: var(--border);
      }
      .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--dim);
        flex-shrink: 0;
        transition: background 0.3s;
      }
      .dot.live {
        background: var(--green);
        box-shadow: 0 0 6px var(--green);
      }
      .dot.off {
        background: var(--danger);
      }
      .dot.test {
        background: var(--warn);
        animation: blink 1.2s infinite;
      }
      @keyframes blink {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.35;
        }
      }
      .conn-label {
        font-size: 12px;
        font-weight: 500;
      }
      .conn-label.live {
        color: var(--green);
      }
      .conn-label.off {
        color: var(--danger);
      }
      .conn-label.test {
        color: var(--warn);
      }
      .device-id {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--muted);
      }
      .hstats {
        margin-left: auto;
        display: flex;
        gap: 18px;
      }
      .hstat {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        color: var(--muted);
      }
      .hstat strong {
        font-family: var(--mono);
        font-size: 13px;
        color: var(--text);
        font-weight: 600;
      }

      /* Layout */
      .layout {
        display: grid;
        grid-template-columns: 300px 1fr 260px;
        flex: 1;
        overflow: hidden;
      }

      /* Left panel */
      .left {
        background: var(--surface);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        overflow-y: auto;
      }
      .left::-webkit-scrollbar {
        width: 5px;
      }
      .left::-webkit-scrollbar-thumb {
        background: var(--border);
        border-radius: 3px;
      }
      .section {
        padding: 14px 15px;
        border-bottom: 1px solid var(--border);
      }
      .stitle {
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.7px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 10px;
      }

      .beh-badge {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: var(--surface2);
        margin-bottom: 10px;
        transition:
          border-color 0.3s,
          background 0.3s;
      }
      .beh-icon {
        font-size: 24px;
      }
      .beh-name {
        font-weight: 600;
        font-size: 15px;
      }
      .beh-sub {
        font-size: 11px;
        color: var(--muted);
      }

      .metrics {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6px;
      }
      .metric {
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 9px 10px;
      }
      .metric.full {
        grid-column: 1 / -1;
      }
      .metric-label {
        font-size: 10px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 3px;
      }
      .metric-value {
        font-family: var(--mono);
        font-size: 16px;
        font-weight: 600;
      }
      .metric-unit {
        font-size: 10px;
        color: var(--muted);
        margin-left: 2px;
      }

      .beh-counts {
        display: flex;
        flex-direction: column;
        gap: 5px;
      }
      .beh-row {
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .beh-row-name {
        font-size: 11px;
        color: var(--muted);
        width: 110px;
        flex-shrink: 0;
      }
      .beh-bar-wrap {
        flex: 1;
        height: 6px;
        background: var(--surface2);
        border-radius: 3px;
        overflow: hidden;
      }
      .beh-bar {
        height: 100%;
        border-radius: 3px;
        transition: width 0.5s ease;
      }
      .beh-count {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--muted);
        width: 28px;
        text-align: right;
      }

      .imu-row {
        margin-bottom: 7px;
      }
      .imu-row:last-child {
        margin-bottom: 0;
      }
      .imu-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 3px;
        font-size: 11px;
        color: var(--muted);
      }
      .imu-header span:last-child {
        font-family: var(--mono);
        color: var(--text);
      }
      .bar-track {
        height: 5px;
        background: var(--surface2);
        border-radius: 3px;
        overflow: hidden;
      }
      .bar-fill {
        height: 100%;
        border-radius: 3px;
        transition: width 0.4s ease;
      }

      .kalman-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6px;
      }
      .kv {
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 8px 10px;
      }
      .kv-label {
        font-size: 10px;
        color: var(--muted);
        text-transform: uppercase;
        margin-bottom: 2px;
      }
      .kv-value {
        font-family: var(--mono);
        font-size: 13px;
        font-weight: 500;
      }

      /* Map */
      #map {
        width: 100%;
        height: 100%;
        z-index: 1;
      }

      /* Right panel */
      .right {
        background: var(--surface);
        border-left: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      .chart-wrap {
        padding: 12px 14px 8px;
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
      }
      .chart-title {
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: var(--muted);
        margin-bottom: 8px;
      }
      canvas#speedChart {
        width: 100% !important;
        height: 100px !important;
      }
      .log-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
      }
      .log-title {
        font-size: 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        color: var(--muted);
        flex: 1;
      }
      .log-list {
        flex: 1;
        overflow-y: auto;
        padding: 6px 10px;
        display: flex;
        flex-direction: column;
        gap: 3px;
      }
      .log-list::-webkit-scrollbar {
        width: 4px;
      }
      .log-list::-webkit-scrollbar-thumb {
        background: var(--border);
        border-radius: 2px;
      }
      .log-item {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 5px;
        padding: 5px 6px;
        border-radius: 5px;
        border-left: 2px solid transparent;
        font-family: var(--mono);
        font-size: 11px;
        animation: fadeIn 0.2s ease;
      }
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateX(4px);
        }
        to {
          opacity: 1;
          transform: none;
        }
      }
      .log-time {
        color: var(--dim);
      }
      .log-beh {
        color: var(--muted);
      }
      .log-spd {
        color: var(--accent);
        text-align: right;
      }
      .empty {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        color: var(--dim);
        font-size: 13px;
        text-align: center;
        padding: 20px;
      }
      .empty svg {
        opacity: 0.3;
      }
    </style>
  </head>
  <body>
    <header class="header">
      <div class="logo">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            d="M12 22s-8-4.5-8-11.8A8 8 0 0112 2a8 8 0 018 8.2c0 7.3-8 11.8-8 11.8z"
          />
          <circle cx="12" cy="10" r="3" />
        </svg>
        GPS Tracker — Group 2
      </div>
      <div class="hdivider"></div>
      <span id="connDot" class="dot"></span>
      <span id="connLabel" class="conn-label">Waiting…</span>
      <div class="hdivider"></div>
      <span id="deviceId" class="device-id">—</span>
      <div class="hstats">
        <div class="hstat">
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"
            />
          </svg>
          <strong id="msgCount">0</strong> msgs
        </div>
        <div class="hstat">
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <circle cx="12" cy="12" r="10" />
            <polyline points="12 6 12 12 16 14" />
          </svg>
          <strong id="lastTime">—</strong>
        </div>
      </div>
    </header>

    <div class="layout">
      <aside class="left">
        <!-- Behaviour -->
        <div class="section">
          <div class="stitle">Driver Behaviour</div>
          <div class="beh-badge" id="behBadge">
            <span class="beh-icon" id="behIcon">⏳</span>
            <div>
              <div class="beh-name" id="behName">Waiting…</div>
              <div class="beh-sub" id="behSub">No data yet</div>
            </div>
          </div>
          <div class="beh-counts" id="behCounts"></div>
        </div>

        <!-- Position -->
        <div class="section">
          <div class="stitle">Position</div>
          <div class="metrics">
            <div class="metric full">
              <div class="metric-label">Filtered Coordinates (Kalman)</div>
              <div class="metric-value" id="latlon" style="font-size: 12px">
                —
              </div>
            </div>
            <div class="metric">
              <div class="metric-label">Speed</div>
              <div class="metric-value" id="speed">
                —<span class="metric-unit">km/h</span>
              </div>
            </div>
            <div class="metric">
              <div class="metric-label">Altitude</div>
              <div class="metric-value" id="altitude">
                —<span class="metric-unit">m</span>
              </div>
            </div>
          </div>
        </div>

        <!-- IMU -->
        <div class="section">
          <div class="stitle">Accelerometer (m/s²)</div>
          <div class="imu-row">
            <div class="imu-header">
              <span>X — lateral</span><span id="ax">—</span>
            </div>
            <div class="bar-track">
              <div
                class="bar-fill"
                id="axBar"
                style="width: 50%; background: var(--accent)"
              ></div>
            </div>
          </div>
          <div class="imu-row">
            <div class="imu-header">
              <span>Y — longitudinal</span><span id="ay">—</span>
            </div>
            <div class="bar-track">
              <div
                class="bar-fill"
                id="ayBar"
                style="width: 50%; background: var(--purple)"
              ></div>
            </div>
          </div>
          <div class="imu-row">
            <div class="imu-header">
              <span>Z — vertical</span><span id="az">—</span>
            </div>
            <div class="bar-track">
              <div
                class="bar-fill"
                id="azBar"
                style="width: 50%; background: var(--green)"
              ></div>
            </div>
          </div>
        </div>

        <!-- Kalman -->
        <div class="section">
          <div class="stitle">Kalman Filter</div>
          <div class="kalman-grid">
            <div class="kv">
              <div class="kv-label">Gain (K)</div>
              <div class="kv-value" id="kGain">—</div>
            </div>
            <div class="kv">
              <div class="kv-label">Uncertainty (P)</div>
              <div class="kv-value" id="kUncert">—</div>
            </div>
          </div>
        </div>
      </aside>

      <div id="map"></div>

      <aside class="right">
        <div class="chart-wrap">
          <div class="chart-title">Speed History (km/h)</div>
          <canvas id="speedChart"></canvas>
        </div>
        <div class="log-header">
          <span class="log-title">Event Log</span>
        </div>
        <div class="log-list" id="logList">
          <div class="empty">
            <svg
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                d="M12 22s-8-4.5-8-11.8A8 8 0 0112 2a8 8 0 018 8.2c0 7.3-8 11.8-8 11.8z"
              />
            </svg>
            Waiting for GPS data…
          </div>
        </div>
      </aside>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
    <script>
      "use strict";

      // Map
      const map = L.map("map").setView([6.3553, 80.5236], 15);
      L.tileLayer(
        "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png",
        {
          attribution: "© OpenStreetMap © CARTO",
          maxZoom: 19,
        },
      ).addTo(map);

      const routeLine = L.polyline([], {
        color: "#58a6ff",
        weight: 3,
        opacity: 0.85,
      }).addTo(map);
      const rawLine = L.polyline([], {
        color: "#484f58",
        weight: 1.5,
        opacity: 0.5,
        dashArray: "4 4",
      }).addTo(map);
      const icon = L.divIcon({
        className: "",
        html: '<div style="width:14px;height:14px;background:#58a6ff;border:2px solid #fff;border-radius:50%;box-shadow:0 0 8px #58a6ff88"></div>',
        iconSize: [14, 14],
        iconAnchor: [7, 7],
      });
      let marker = null,
        firstFix = true;

      function updateMap(data, history) {
        const ll = [data.lat, data.lon];
        if (!marker) marker = L.marker(ll, { icon }).addTo(map);
        else marker.setLatLng(ll);
        routeLine.setLatLngs(history.map((h) => [h.lat, h.lon]));
        rawLine.setLatLngs(history.map((h) => [h.lat_raw, h.lon_raw]));
        if (firstFix) {
          map.setView(ll, 16);
          firstFix = false;
        } else map.panTo(ll, { animate: true, duration: 0.5 });
        marker.bindPopup(
          `<b>${data.behaviour}</b><br>${data.lat.toFixed(6)}, ${data.lon.toFixed(6)}<br>${data.speed} km/h`,
        );
      }

      // Speed chart
      const speedData = {
        labels: [],
        datasets: [
          {
            data: [],
            borderColor: "#58a6ff",
            backgroundColor: "rgba(88,166,255,.12)",
            borderWidth: 2,
            pointRadius: 0,
            tension: 0.4,
            fill: true,
          },
        ],
      };
      const speedChart = new Chart(document.getElementById("speedChart"), {
        type: "line",
        data: speedData,
        options: {
          responsive: true,
          maintainAspectRatio: false,
          animation: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { display: false },
            y: {
              beginAtZero: true,
              ticks: { color: "#484f58", font: { size: 10 } },
              grid: { color: "rgba(48,54,61,.5)" },
            },
          },
        },
      });

      function pushSpeed(time, speed) {
        speedData.labels.push(time);
        speedData.datasets[0].data.push(speed);
        if (speedData.labels.length > 40) {
          speedData.labels.shift();
          speedData.datasets[0].data.shift();
        }
        speedChart.update("none");
      }

      // Behaviour config
      const BEH = {
        NORMAL: {
          icon: "🟢",
          label: "Normal",
          color: "#3fb950",
          sub: "Smooth driving",
        },
        HARSH_BRAKING: {
          icon: "🔴",
          label: "Harsh Braking",
          color: "#f85149",
          sub: "Sudden deceleration",
        },
        RAPID_ACCEL: {
          icon: "🟠",
          label: "Rapid Accel",
          color: "#d29922",
          sub: "Hard acceleration",
        },
        SHARP_TURN: {
          icon: "🟣",
          label: "Sharp Turn",
          color: "#bc8cff",
          sub: "Lateral G-force",
        },
      };

      function updateBehaviour(beh, behaviours) {
        const cfg = BEH[beh] || BEH.NORMAL;
        document.getElementById("behIcon").textContent = cfg.icon;
        document.getElementById("behName").textContent = cfg.label;
        document.getElementById("behSub").textContent = cfg.sub;
        const badge = document.getElementById("behBadge");
        badge.style.borderColor = cfg.color + "55";
        badge.style.background = cfg.color + "15";

        const total = Math.max(
          Object.values(behaviours).reduce((a, b) => a + b, 0),
          1,
        );
        const order = ["NORMAL", "HARSH_BRAKING", "RAPID_ACCEL", "SHARP_TURN"];
        document.getElementById("behCounts").innerHTML = order
          .map((k) => {
            const c = BEH[k],
              cnt = behaviours[k] || 0,
              pct = Math.round((cnt / total) * 100);
            return `<div class="beh-row">
      <span class="beh-row-name">${c.label}</span>
      <div class="beh-bar-wrap"><div class="beh-bar" style="width:${pct}%;background:${c.color}"></div></div>
      <span class="beh-count">${cnt}</span>
    </div>`;
          })
          .join("");
      }

      function pct(v, min, max) {
        return Math.max(0, Math.min(100, ((v - min) / (max - min)) * 100));
      }

      function updateIMU(ax, ay, az) {
        document.getElementById("ax").textContent = ax.toFixed(3);
        document.getElementById("ay").textContent = ay.toFixed(3);
        document.getElementById("az").textContent = az.toFixed(3);
        document.getElementById("axBar").style.width = pct(ax, -2, 2) + "%";
        document.getElementById("ayBar").style.width = pct(ay, -2, 2) + "%";
        document.getElementById("azBar").style.width = pct(az, 8, 12) + "%";
      }

      // Event log
      let logItems = [],
        logInited = false;
      function pushLog(data) {
        const cfg = BEH[data.behaviour] || BEH.NORMAL;
        logItems.unshift({
          time: data.time,
          beh: cfg.label,
          spd: data.speed,
          color: cfg.color,
        });
        if (logItems.length > 60) logItems.pop();
        const list = document.getElementById("logList");
        if (!logInited) {
          list.innerHTML = "";
          logInited = true;
        }
        list.innerHTML = logItems
          .map(
            (item) =>
              `<div class="log-item" style="border-left-color:${item.color}">
      <span class="log-time">${item.time}</span>
      <span class="log-beh">${item.beh}</span>
      <span class="log-spd">${item.spd} km/h</span>
    </div>`,
          )
          .join("");
      }

      function setConnStatus(connected, testMode) {
        const dot = document.getElementById("connDot"),
          label = document.getElementById("connLabel");
        if (testMode) {
          dot.className = "dot test";
          label.className = "conn-label test";
          label.textContent = "Test Mode";
        } else if (connected) {
          dot.className = "dot live";
          label.className = "conn-label live";
          label.textContent = "Live MQTT";
        } else {
          dot.className = "dot off";
          label.className = "conn-label off";
          label.textContent = "Disconnected";
        }
      }

      // Socket.IO
      const socket = io();
      socket.on("gps_update", ({ data, history, behaviours }) => {
        document.getElementById("msgCount").textContent = data.msg_count;
        document.getElementById("lastTime").textContent = data.time;
        document.getElementById("deviceId").textContent = data.device_id;
        document.getElementById("latlon").textContent =
          `${data.lat.toFixed(6)}, ${data.lon.toFixed(6)}`;
        document.getElementById("speed").innerHTML =
          `${data.speed}<span class="metric-unit">km/h</span>`;
        document.getElementById("altitude").innerHTML =
          `${data.altitude}<span class="metric-unit">m</span>`;
        document.getElementById("kGain").textContent = data.kalman_gain;
        document.getElementById("kUncert").textContent = data.uncertainty;
        updateBehaviour(data.behaviour, behaviours);
        updateIMU(data.accel_x, data.accel_y, data.accel_z);
        updateMap(data, history);
        pushSpeed(data.time, data.speed);
        pushLog(data);
        setConnStatus(true, data.device_id.includes("TEST"));
      });
      socket.on("disconnect", () => setConnStatus(false, false));
      fetch("/api/stats")
        .then((r) => r.json())
        .then((s) => setConnStatus(s.connected, s.test_mode))
        .catch(() => {});
    </script>
  </body>
</html>
